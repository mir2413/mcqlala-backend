# Server Configuration
PORT=3004
NODE_ENV=development

# CORS - Update for production (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:3004

# JWT Secret - CHANGE THIS IN PRODUCTION!
JWT_SECRET=your_jwt_secret_here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Login Rate Limiting (stricter)
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX_REQUESTS=5

# MongoDB - Set your connection string here
# Example: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGODB_URI=

# Email Configuration (for forgot password)
EMAIL_USER=
EMAIL_PASS=

# Frontend URL (for password reset links)
FRONTEND_URL=http://localhost:3004

# HTTPS Configuration (uncomment for production with SSL)
# SSL_KEY_PATH=/path/to/private.key
# SSL_CERT_PATH=/path/to/certificate.crt
# SSL_CA_PATH=/path/to/ca_bundle.crt
